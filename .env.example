# ──────────────────────────────────────────────────────────
# La Krème SaaS — Variables d'environnement LOCAL DEV
# Copier ce fichier en .env.local et remplir les vraies valeurs
# ──────────────────────────────────────────────────────────

# Supabase (obligatoire pour l'auth)
# Récupérer depuis : https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.VOTRE_ANON_KEY

# Backend reservation_service (local Docker)
VITE_API_URL=http://localhost:8001
VITE_WIDGET_BASE_URL=http://localhost:8001

# (optionnel) URL de l'API principale lakreme.fr (pour la recherche brunch_places)
VITE_MEILLEURBRUNCH_API_URL=https://api.lakreme.fr
